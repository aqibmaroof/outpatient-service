{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/what-to-expect/layout,_N_T_/what-to-expect/page,_N_T_/what-to-expect"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/what-to-expect/__PAGE__",
    "/what-to-expect",
    "/_index",
    "/_head"
  ]
}